{
  "name": "nice-icons",
  "version": "3.1.1",
  "description": "A collection of SVG icons with stroke and fill variants",
  "main": "src/generated/index.js",
  "types": "src/generated/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "node scripts/generateIndex/index.js",
    "dev": "node scripts/generateIndex/index.js --watch",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "author": "Nice Prototypes",
  "license": "MIT",
  "keywords": [
    "icons",
    "svg",
    "nice-icons"
  ],
  "files": [
    "src/generated",
    "src/services"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nice-prototypes/nice-icons"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {},
  "devDependencies": {
    "nice-svg-generator": "file:../svg-generator"
  },
  "dependencies": {
    "nice-styles": "file:../styles"
  },
  "exports": {
    ".": {
      "types": "./src/generated/index.d.ts",
      "default": "./src/generated/index.js"
    },
    "./catalog": {
      "types": "./src/generated/catalog.d.ts",
      "default": "./src/generated/catalog.js"
    },
    "./source": {
      "types": "./src/generated/source.d.ts",
      "default": "./src/generated/source.js"
    },
    "./base64": {
      "types": "./src/generated/base64.d.ts",
      "default": "./src/generated/base64.js"
    },
    "./get-icon": {
      "types": "./src/services/getIcon.d.ts",
      "default": "./src/services/getIcon.js"
    },
    "./get-icon-encoded": {
      "types": "./src/services/getIconEncoded.d.ts",
      "default": "./src/services/getIconEncoded.js"
    },
    "./*": "./src/generated/*"
  }
}
